# Servidor
PORT=3000

# Base de datos
# Opción A (recomendada en hostings como Render): una única URL de conexión.
# Si se define DATABASE_URL, las variables DB_* de abajo se ignoran.
# DATABASE_URL=postgresql://usuario:password@host:5432/nombre_bd

# Opción B (desarrollo local con docker-compose): variables sueltas.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=restaurant_db
DB_USER=postgres
DB_PASSWORD=postgres

# SSL: activado por defecto (Render y la mayoría de hostings lo exigen), tanto
# con DATABASE_URL como con las variables DB_* sueltas. El Postgres local de
# docker-compose no soporta SSL, así que en desarrollo local hay que
# desactivarlo explícitamente:
DB_SSL=false

# JWT — cambia esto por un secreto aleatorio en producción
JWT_SECRET=change_this_to_a_long_random_secret
